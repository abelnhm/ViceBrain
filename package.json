{
  "name": "vicebrain",
  "version": "1.0.0",
  "description": "ViceBrain - All major AI chats side by side",
  "author": "ViceBrain Team / Abel Naharro",
  "warning": "⚠ DISCLAIMER: This software is provided for EDUCATIONAL purposes only. The author is NOT liable for ToS violations, account suspensions, or legal consequences. USE AT YOUR OWN RISK. See LICENSE file for full terms.",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.vicebrain.app",
    "productName": "ViceBrain",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/",
      "assets/",
      "node_modules/"
    ],
    "extraMetadata": {
      "main": "src/main/index.js"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icons/windows/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icons/macos/icon.icns"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "assets/icons/linux/icons"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
