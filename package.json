{
  "name": "vicebrain",
  "version": "1.0.0",
  "description": "ViceBrain - All major AI chats side by side",
  "author": "ViceBrain Team / Abel Naharro",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.vicebrain.app",
    "productName": "ViceBrain",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/",
      "assets/",
      "node_modules/"
    ],
    "extraMetadata": {
      "main": "src/main/index.js"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/windows/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icons/macos/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icons/linux/icons"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
